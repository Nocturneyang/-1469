# ==========================================
# WhatsApp Monitor 配置文件
# 使用方法：复制此文件，重命名为 .env，填入你自己的密钥
# ==========================================

# AI 模型配置 (兼容 OpenAI 格式的接口，如 DeepSeek, Kimi, 阿里通义等)
AI_API_URL="https://api.moonshot.cn/v1/chat/completions"
AI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AI_MODEL_NAME="moonshot-v1-8k"

# 钉钉自定义机器人 Webhook
# 获取方式：钉钉群 → 群设置 → 智能群助手 → 添加机器人 → 自定义
DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx"

# 钉钉机器人加签密钥（如果机器人设置了"加签"安全方式则填写，否则留空）
DINGTALK_SECRET=""
